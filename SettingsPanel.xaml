<UserControl x:Class="YmmAivoice2Plugin.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="260">

    <StackPanel Margin="8" VerticalAlignment="Top">

        <TextBlock Text="AIVOICE2 Helper" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

        <!-- 無音閾値 -->
        <TextBlock Text="無音閾値 (dB)" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="ThresholdSlider"
                    Grid.Column="0"
                    Minimum="-60" Maximum="-10"
                    Value="-40"
                    TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    ValueChanged="ThresholdSlider_ValueChanged"
                    VerticalAlignment="Center"/>
            <TextBlock x:Name="ThresholdLabel"
                       Grid.Column="1"
                       Text="-40 dB"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"/>
        </Grid>

        <!-- 末尾マージン -->
        <TextBlock Text="末尾マージン (ms)" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="MarginSlider"
                    Grid.Column="0"
                    Minimum="0" Maximum="200"
                    Value="50"
                    TickFrequency="10"
                    IsSnapToTickEnabled="True"
                    ValueChanged="MarginSlider_ValueChanged"
                    VerticalAlignment="Center"/>
            <TextBlock x:Name="MarginLabel"
                       Grid.Column="1"
                       Text="50 ms"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"/>
        </Grid>

        <!-- 実行ボタン -->
        <Button Content="整理を実行"
                x:Name="ExecuteButton"
                Padding="8,4"
                HorizontalAlignment="Stretch"
                Click="ExecuteButton_Click"/>

        <!-- 結果表示 -->
        <TextBlock x:Name="ResultLabel"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Foreground="#555"/>

    </StackPanel>
</UserControl>
