<UserControl x:Class="YmmAivoice2Plugin.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="260">

    <StackPanel Margin="8" VerticalAlignment="Top">

        <TextBlock Text="AIVOICE2 Helper" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

        <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12">
            AIVOICE2で書き出したWAVを連番順に並べ替え、掛け合い形式に整理します。
        </TextBlock>

        <Button Content="整理を実行"
                Command="{Binding ExecuteCommand}"
                Padding="8,4"
                HorizontalAlignment="Stretch"/>

        <TextBlock Text="{Binding ResultText}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Foreground="#555"/>

    </StackPanel>
</UserControl>
