<UserControl x:Class="YmmAivoice2Plugin.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="260">

    <StackPanel Margin="8" VerticalAlignment="Top">

        <TextBlock Text="AIVOICE2 Helper  v0.7.0" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

        <CheckBox Content="ファイル追加時に自動整理"
                  IsChecked="{Binding AutoWatch, Mode=TwoWay}"
                  Margin="0,0,0,4"/>
        <TextBlock Text="ONにすると新しいWAVが配置されるたびに自動で整理します"
                   Foreground="#888" FontSize="10" Margin="20,0,0,12"/>

        <Button Content="今すぐ整理"
                Command="{Binding ExecuteCommand}"
                Padding="8,4" HorizontalAlignment="Stretch"/>

        <TextBlock Text="{Binding ResultText}"
                   Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555"/>

    </StackPanel>
</UserControl>
