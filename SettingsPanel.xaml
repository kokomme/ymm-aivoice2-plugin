<UserControl x:Class="YmmAivoice2Plugin.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="260">

    <StackPanel Margin="8" VerticalAlignment="Top">

        <TextBlock Text="AIVOICE2 Helper" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

        <!-- 無音閾値 -->
        <TextBlock Text="無音閾値 (dB)" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="-60" Maximum="-10"
                    Value="{Binding SilenceThresholdDb, Mode=TwoWay}"
                    TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding ThresholdText}"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"/>
        </Grid>

        <!-- 末尾マージン -->
        <TextBlock Text="末尾マージン (ms)" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="0" Maximum="200"
                    Value="{Binding TailMarginMs, Mode=TwoWay}"
                    TickFrequency="10"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding MarginText}"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"/>
        </Grid>

        <!-- 実行ボタン -->
        <Button Content="整理を実行"
                Command="{Binding ExecuteCommand}"
                Padding="8,4"
                HorizontalAlignment="Stretch"/>

        <!-- 結果表示 -->
        <TextBlock Text="{Binding ResultText}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Foreground="#555"/>

    </StackPanel>
</UserControl>
